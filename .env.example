# Copy to .env and edit for local dev.
DATABASE_URL=sqlite:///./pos.db
# Supabase example:
# DATABASE_URL=postgresql+psycopg://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require
AUTH_PROVIDER=supabase
# Set to your Supabase project's JWT secret (Settings -> API -> JWT Secret)
SUPABASE_JWT_SECRET=change-me
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# For local dev only:
# AUTO_CREATE_SCHEMA=true

ACCESS_TOKEN_EXPIRE_MINUTES=720
TIMEZONE=Asia/Kolkata
